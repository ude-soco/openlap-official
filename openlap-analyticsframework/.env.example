# OpenLAP Analytics Framework — supported environment variables
#
# NOTE: Spring Boot does NOT auto-load this file. It documents every supported
# variable with its local-development default. For a plain host run the built-in
# defaults already match these values, so you normally need to set nothing.
# To use it, export the vars (e.g. `set -a; source .env.example; set +a`) or pass
# it to Docker with `--env-file`.

# --- HTTP server ---
PORT=8090                          # Port the backend listens on (all routes under /api)

# --- Logging ---
LOG_LEVEL=warn                     # Root log level; use INFO to see startup & Mongo logs
DEBUG=false                        # Spring Boot auto-configuration debug report

# --- Primary MongoDB (application data) ---
MONGODB_PRIMARY_URI=mongodb://127.0.0.1:27017/openlap_v2   # Primary connection URI
OPENLAP_MONGODB_DB=openlap_v2      # Primary database name (this is the name the app uses)

# --- Secondary MongoDB (xAPI / Learning Locker statements) ---
MONGODB_SECONDARY_URI=mongodb://127.0.0.1:27017/learninglocker_v2  # Secondary connection URI
LRS_MONGODB_DB=learninglocker_v2   # Secondary database name

# --- Plugin JAR storage ---
DATA_DIR=.                         # Base dir for jars/analytics_techniques & jars/visualization_methods

# --- Frontend / CORS ---
WEBAPP_URL=http://localhost:5173   # Allowed frontend origin(s) for CORS

# --- Seed administrator (created automatically on first startup) ---
ADMIN_NAME=admin
ADMIN_EMAIL=admin@mail.com
ADMIN_PASSWORD=1234qweR

# --- Security ---
JWT_SECRET_KEY=secret              # HMAC secret used to sign JWT access/refresh tokens
# Fail-fast guard: with the defaults above (JWT_SECRET_KEY=secret, ADMIN_PASSWORD=1234qweR) the
# app refuses to start. Either set strong values for the two secrets, OR set the flag below to
# true for LOCAL DEVELOPMENT ONLY (downgrades the startup failure to a warning). Never in prod.
ALLOW_INSECURE_DEFAULTS=false
