docs
compose.yaml
.gitignore
.dockerignore

# Host build output — the image rebuilds this with `mvn package` inside the
# container, so the host's target/ must never enter the build context.
target

# Plugin JARs generated by the app at runtime. They must NOT be copied into the
# image (a stale plugin JAR breaks startup). The folders themselves are kept via
# their .gitkeep files, so the Dockerfile's `COPY ./jars` still works.
jars/analytics_techniques/*.jar
jars/visualization_methods/*.jar

# OS-generated junk that should never enter the build context.
**/.DS_Store
